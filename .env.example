# MyHealth-Europe — Environment variables example.
# Copy to `.env` and adjust. The .env file is gitignored.

# -----------------------------------------------------------------------------
# Compose project + image naming
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=myhealth-europe
DOCKER_IMAGE=myhealth-europe

# Set on every release. Production compose requires VERSION to be non-empty.
VERSION=dev
COMMIT=unknown

# Production-only — registry path for `docker compose pull`.
# DOCKER_REGISTRY=ghcr.io/sattva2020

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
APP_PORT=7777
RUST_LOG=info

# -----------------------------------------------------------------------------
# Optional integrations (read by MCP servers configured in .mcp.json)
# -----------------------------------------------------------------------------
# GITHUB_TOKEN=ghp_xxx
# DATABASE_URL=postgres://user:password@localhost:5432/myhealth_dev
